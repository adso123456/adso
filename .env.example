# ==========================================
# Minecraft Agent 中心化配置文件
# 复制此文件为 .env 并修改对应的值
# ==========================================

# ==========================================
# 一、服务配置
# ------------------------------------------

# Minecraft Bot 服务地址
BOT_URL=http://localhost:3001

# Python 聊天服务监听地址
CHAT_SERVICE_HOST=0.0.0.0
CHAT_SERVICE_PORT=8000

# Minecraft 服务器连接端口
MC_SERVER_PORT=25565

# ==========================================
# 二、向量知识库配置
# ------------------------------------------

# 向量数据库持久化目录
VECTOR_DB_DIR=./vector_db

# HuggingFace 端点（使用镜像站加速）
HF_ENDPOINT=https://hf-mirror.com

# ==========================================
# 三、模型配置
# ------------------------------------------

# DashScope API Key（必填）
# 获取地址：https://dashscope.aliyun.com/
DASHSCOPE_API_KEY=your_api_key_here

# 通义千问模型名称
# qwen-turbo: 速度快，成本低，适合闲聊
# qwen-plus: 速度平衡，效果好，适合指令执行
# qwen-max: 效果最好，成本高
LLM_CHAT_MODEL=qwen-turbo
LLM_COMMAND_MODEL=qwen-plus

# Embedding 模型名称（向量检索用）
EMBEDDING_MODEL=shibing624/text2vec-base-chinese

# Embedding 模型设备
# cpu: 使用 CPU（推荐服务器环境）
# cuda: 使用 GPU
EMBEDDING_DEVICE=cpu

# ==========================================
# 四、持久化配置
# ------------------------------------------

# 聊天记忆文件
MEMORY_FILE=chat_memory.json

# 聊天记忆最大保留条数
MAX_MEMORY_HISTORY=200

# ==========================================
# 五、向量库集合名称
# ------------------------------------------

# Wiki 知识库集合名
COLLECTION_WIKI=minecraft_wiki

# 技能库集合名
COLLECTION_SKILLS=learned_skills

# 游戏记忆集合名
COLLECTION_MEMORY=game_memory

# ==========================================
# 六、Wiki 数据配置
# ------------------------------------------

# Wiki 数据文件
WIKI_DATA_FILE=wiki_data.json

# ==========================================
# 七、开发/调试配置
# ------------------------------------------

# 是否启用向量知识库（调试时可关闭以加快启动速度）
ENABLE_VECTOR_STORE=true
